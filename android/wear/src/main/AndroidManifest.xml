<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.thoth.dreamarchive.wear">

    <!-- Audio recording -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Firebase / network upload -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Keep screen on during recording -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Vibration for haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Declare this is a WearOS app -->
    <uses-feature android:name="android.hardware.type.watch" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.ThothWear">

        <!-- WearOS standalone — does NOT require a companion phone app -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".MainWearActivity"
            android:exported="true"
            android:theme="@style/Theme.ThothWear">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
